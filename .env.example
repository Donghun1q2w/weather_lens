# PhotoSpot Korea - Environment Variables Example
# Copy this file to .env and fill in your values

# 기상청 API
# - data.go.kr: 공공데이터포털 (https://data.go.kr, 격자 좌표 기반)
# - apihub.kma.go.kr: 기상청 API 허브 (https://apihub.kma.go.kr, 지역명 기반)
KMA_API_KEY=your_kma_api_key_here
KMA_API_SOURCE=data.go.kr

# 에어코리아 API (https://www.airkorea.or.kr)
AIRKOREA_API_KEY=your_airkorea_api_key_here

# 바다누리 API (https://www.khoa.go.kr)
KHOA_API_KEY=your_khoa_api_key_here

# Kakao Maps (확장 단계, https://developers.kakao.com)
KAKAO_REST_API_KEY=your_kakao_api_key_here

# Gemini AI (https://ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Supabase (확장 단계, https://supabase.com)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# 환경 설정
ENVIRONMENT=development
LOG_LEVEL=INFO
